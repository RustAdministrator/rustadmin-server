{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustAdmin Server",
  "version": "0.1.2",
  "identifier": "io.github.rustadministrator.rustadmin.server",
  "mainBinaryName": "rustadmin_server",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5177/",
    "frontendDist": "html/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "center": true,
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "RustAdmin Server",
        "width": 980
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "",
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
