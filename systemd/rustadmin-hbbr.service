
[Unit]
Description=RustAdmin Relay Server

[Service]
Type=simple
LimitNOFILE=1000000
ExecStart=/usr/bin/hbbr
WorkingDirectory=/var/lib/rustadmin-server/
User=
Group=
Restart=always
StandardOutput=append:/var/log/rustadmin-server/hbbr.log
StandardError=append:/var/log/rustadmin-server/hbbr.error
# Restart service after 10 seconds if node service crashes
RestartSec=10

[Install]
WantedBy=multi-user.target

